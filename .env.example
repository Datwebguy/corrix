# CROO CAP — from agent.croo.network dashboard (shown once)
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_your_provider_key_here

# Optional Base RPC (defaults to https://mainnet.base.org)
# BASE_RPC_URL=https://mainnet.base.org

# Requester agent (A2A demo) — second agent SDK key
# CROO_REQUESTER_SDK_KEY=croo_sk_requester_key
# CROO_TARGET_SERVICE_ID=your-verify-service-id

# Provider mock mode: MOCK=1 skips live CAP and only runs local engine
# MOCK=1
