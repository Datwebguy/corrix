# CROO CAP — copy to .env and fill real values (never commit .env)
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Provider agent (Corrix) — accepts verify jobs
CROO_SDK_KEY=croo_sk_your_provider_key_here

# Requester / buyer agent — pays for hires (do not reuse provider key)
CROO_REQUESTER_SDK_KEY=croo_sk_your_requester_key_here

# UUID of the verify service on the provider agent
CROO_TARGET_SERVICE_ID=your-verify-service-uuid

# Optional Base RPC for balance checks
# BASE_RPC_URL=https://mainnet.base.org

# Local engine only (no CAP network): LOCAL=1
# LOCAL=1
